{
  "manifest_version": 3,
  "name": "GMeet Sign Language Translator",
  "version": "1.0",
  "description": "Displays sign language videos in the corner during Google Meet calls for spoken words",
  "permissions": ["activeTab", "microphone"],
  "content_scripts": [
    {
      "matches": ["https://meet.google.com/*", "file://*"],
      "js": ["content.js"],
      "css": ["content.css"]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["videos/*"],
      "matches": ["<all_urls>"]
    }
  ]
}